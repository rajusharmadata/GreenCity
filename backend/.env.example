# ====================================
# 🚀 GreenCity Backend Configuration
# ====================================

# 🌐 Server Configuration
# =======================
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# 🔒 Security
# ==========
# Generate strong secrets for production
JWT_SECRET=your-jwt-secret-key-32-char-min
SESSION_SECRET=your-session-secret-key-32-char-min

# 🗄️ Database (MongoDB)
# ====================
# Local Development
MONGO_URI=mongodb://127.0.0.1:27017/greencity_project
# Production (MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/greencity?retryWrites=true&w=majority

# 🔑 Authentication
# ================
# JWT
JWT_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES=30

# 🔄 CORS
# ======
CORS_ORIGIN=http://localhost:5173,https://your-vercel-app.vercel.app

# 📧 Email (Nodemailer)
# ===================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=no-reply@greencity.com

# 🌐 OAuth Providers
# =================
# Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=/api/v1/auth/google/callback

# GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=/api/v1/auth/github/callback

# 🚀 Frontend URLs (for OAuth redirects)
# ===================================
FRONTEND_URL=http://localhost:5173
VERCEL_URL=https://your-vercel-app.vercel.app

# ⚙️ Rate Limiting
# ===============
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100           # Max requests per window
AUTH_RATE_LIMIT_MAX=5        # Max auth attempts per window

# 🔍 Logging
# =========
LOG_LEVEL=info  # error, warn, info, debug
ENABLE_REQUEST_LOGGING=true

# 🛠️ Development
# =============
DEBUG=app:*,api:*,auth:*
NODE_OPTIONS=--max_old_space_size=4096

# 🤖 AI (Gemini Vision)
# ====================
GEMINI_API_KEY=your-gemini-api-key
# Optional: override the model used by the AI service
GEMINI_MODEL=gemini-1.5-flash

# 🗺️ Maps (OpenRouteService) - used for eco routes
# ================================================
OPENROUTESERVICE_API_KEY=your-openrouteservice-api-key
